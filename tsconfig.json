{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "noEmit": true,
    "declaration": true,
    "declarationMap": true,

    "paths": {
      "@hive-sdk/agent": ["./packages/agent/src/index.ts"],
      "@hive-sdk/agent/*": ["./packages/agent/src/*"],
      "@hive-sdk/tools": ["./packages/tools/src/index.ts"],
      "@hive-sdk/tools/*": ["./packages/tools/src/*"],
      "@hive-sdk/skills": ["./packages/skills/src/index.ts"],
      "@hive-sdk/skills/*": ["./packages/skills/src/*"],
      "@hive-sdk/mcp": ["./packages/mcp/src/index.ts"],
      "@hive-sdk/mcp/*": ["./packages/mcp/src/*"],
      "@hive-sdk/tts": ["./packages/tts/src/index.ts"],
      "@hive-sdk/tts/*": ["./packages/tts/src/*"],
      "@hive-sdk/storage": ["./packages/storage/src/index.ts"],
      "@hive-sdk/storage/*": ["./packages/storage/src/*"],
      "@hive-sdk/channels": ["./packages/channels/src/index.ts"],
      "@hive-sdk/channels/*": ["./packages/channels/src/*"],
      "@hive-sdk/gateway": ["./packages/gateway/src/index.ts"],
      "@hive-sdk/gateway/*": ["./packages/gateway/src/*"],
      "@hive-sdk/scheduler": ["./packages/scheduler/src/index.ts"],
      "@hive-sdk/scheduler/*": ["./packages/scheduler/src/*"],
      "@hive-sdk/events": ["./packages/events/src/index.ts"],
      "@hive-sdk/events/*": ["./packages/events/src/*"],
      "@hive-sdk/state": ["./packages/state/src/index.ts"],
      "@hive-sdk/state/*": ["./packages/state/src/*"],
      "@hive-sdk/security": ["./packages/security/src/index.ts"],
      "@hive-sdk/security/*": ["./packages/security/src/*"],
      "@hive-sdk/config": ["./packages/config/src/index.ts"],
      "@hive-sdk/config/*": ["./packages/config/src/*"],
      "@hive-sdk/utils": ["./packages/utils/src/index.ts"],
      "@hive-sdk/utils/*": ["./packages/utils/src/*"],
      "@hive-sdk/canvas": ["./packages/canvas/src/index.ts"],
      "@hive-sdk/canvas/*": ["./packages/canvas/src/*"],
      "@hive-sdk/voice": ["./packages/voice/src/index.ts"],
      "@hive-sdk/voice/*": ["./packages/voice/src/*"],
      "@hive-sdk/multimodal": ["./packages/multimodal/src/index.ts"],
      "@hive-sdk/multimodal/*": ["./packages/multimodal/src/*"],
      "@hive-sdk/heartbeat": ["./packages/heartbeat/src/index.ts"],
      "@hive-sdk/heartbeat/*": ["./packages/heartbeat/src/*"],
      "@hive-sdk/plugins": ["./packages/plugins/src/index.ts"],
      "@hive-sdk/plugins/*": ["./packages/plugins/src/*"],
      "@hive-sdk/auth": ["./packages/auth/src/index.ts"],
      "@hive-sdk/auth/*": ["./packages/auth/src/*"],
      "@hive-sdk/resilience": ["./packages/resilience/src/index.ts"],
      "@hive-sdk/resilience/*": ["./packages/resilience/src/*"]
    }
  },
  "include": [
    "packages/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}